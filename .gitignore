# Виртуальное окружение (если случайно окажется здесь)
.venv/
venv/
ENV/
env/

# Python кэш и байт-код
__pycache__/
*.py[cod]
*.so

# Логи и временные файлы
*.log
*.tmp
*.bak

# Файлы IDE (например, VSCode, PyCharm)
.vscode/
.idea/
*.swp

# Сгенерированный index.html (не обязательно, но многие исключают,
# чтобы не было конфликтов; в вашем случае он нужен для GitHub Pages,
# поэтому не исключайте, если он должен быть в репозитории.
# Я рекомендую оставить index.html в репозитории (он нужен для Pages).
# Но если вы всегда генерируете его перед деплоем, можно добавить:
# index.html

# Файлы операционной системы
.DS_Store
Thumbs.db